# =============================================================================
# DATA LABELLING APP — Environment variables (copy to .env and fill in)
# =============================================================================

JWT_SECRET_KEY=REPLACE_WITH_OPENSSL_RAND_BASE64_32

MONGODB_URI=mongodb://mongodb:27017/

MONGODB_DATABASE=datalabellingapp
MONGODB_MEDIAS_DB=medias
MONGODB_MAX_POOL_SIZE=50
MONGODB_MIN_POOL_SIZE=10
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_RETRY_WRITES=true

ACCESS_TOKEN_EXPIRE_MINUTES=1440

FLASK_ENV=production
PORT=5000
CORS_ORIGINS=*
MAX_CONTENT_LENGTH_MB=25

GUNICORN_WORKERS=5
GUNICORN_THREADS=3
GUNICORN_TIMEOUT=120

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

S3_STORAGE_ENABLED=false
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET=medias
S3_ACCESS_KEY=REPLACE_MINIO_ACCESS_KEY
S3_SECRET_KEY=REPLACE_MINIO_SECRET_KEY
S3_REGION=us-east-1

GRAFANA_ADMIN_PASSWORD=strong-password

KAGGLE_ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY

DEFAULT_ADMIN_EMAIL=admin@dla.local
DEFAULT_ADMIN_PASSWORD=Change-me!
DEFAULT_ADMIN_NAME=Admin DLA
